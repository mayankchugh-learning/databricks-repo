{
  "custom_summary": "Mayank Chugh High Priority",
  "evaluation": {
    "source": {
      "name": "total_amount",
      "display": "source",
      "aggregation": "SUM"
    },
    "comparison_operator": "GREATER_THAN_OR_EQUAL",
    "threshold": {
      "value": {
        "double_value": 500000.0
      }
    },
    "empty_result_state": "ERROR",
    "notification": {
      "retrigger_seconds": 0,
      "notify_on_ok": true
    }
  },
  "schedule": {
    "quartz_cron_schedule": "59 0 0 * * ?",
    "timezone_id": "Asia/Hong_Kong"
  },
  "query_lines": [
    "select ",
    "    sum(total_amount) as total_amount",
    "  from databricksmayank.silver.sales_enr"
  ],
  "custom_description_lines": [
    "Hey Mayank; This is the alert or you from databricks. ",
    "",
    "{{ALERT_COLUMN}}"
  ]
}
